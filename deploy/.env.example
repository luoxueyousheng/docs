# 复制本文件为 deploy/.env，填入真实值后再 docker compose up -d。
# 注意：.env 含明文密钥，已被 .gitignore 排除，切勿提交到仓库。

# 你自己定的一串随机密钥；服务器和 GitHub Secret 两边必须完全一致。
# 生成示例：openssl rand -hex 32
WEBHOOK_TOKEN=

# Docker Hub 用户名 + 访问令牌（令牌在 hub.docker.com → Account Settings → Security 创建）
DOCKERHUB_USER=yiminger
DOCKERHUB_TOKEN=

# 镜像名与站点对外端口（一般保持默认即可）
IMAGE_NAME=yiminger/jadeview_docs:latest
SITE_PORT=8088
