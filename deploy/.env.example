# 复制本文件为 deploy/.env，填入真实值后再 docker compose up -d。
# 注意：.env 含明文密钥，已被 .gitignore 排除，切勿提交到仓库。

# 你自己定的一串随机密钥；服务器和 GitHub Secret 两边必须完全一致。
# 生成示例：openssl rand -hex 32
WEBHOOK_TOKEN=

# Docker Hub 用户名 + 访问令牌（令牌在 hub.docker.com → Account Settings → Security 创建）
DOCKERHUB_USER=yiminger
DOCKERHUB_TOKEN=

# 镜像名与站点对外端口（一般保持默认即可）
IMAGE_NAME=yiminger/jadeview_docs:latest
SITE_PORT=8088

# ── 文档 MCP 服务（search_docs / get_doc）──
# 镜像名（由 CI 构建推送）；如在服务器本地构建则用不到。
MCP_IMAGE_NAME=yiminger/jadeview_docs_mcp:latest
# MCP 对外端口（你的反代指向它，容器内固定 8848）。
MCP_PORT=8848
# 生成文档 url 用的站点前缀（search 结果里的 url 会用它拼）。
BASE_URL=https://jade.run
# 可选鉴权：设置后 POST /mcp 需带 Authorization: Bearer <token>；留空=不鉴权。
MCP_AUTH_TOKEN=
