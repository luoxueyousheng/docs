{
  "name": "jadeview-docs-mcp",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted MCP server for JadeView docs (search + full-text over local markdown)",
  "main": "dist/server.js",
  "bin": {
    "jadeview-docs-mcp": "dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "reindex": "tsx src/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
